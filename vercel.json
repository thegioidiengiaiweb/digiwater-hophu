  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    { "source": "/about.html", "destination": "/ve-digiwater", "permanent": true },
    { "source": "/services.html", "destination": "/dich-vu-xet-nghiem-nuoc-digiwater", "permanent": true },
    { "source": "/contact.html", "destination": "/lien-he-digiwater", "permanent": true }
  ],
  "rewrites": [
    { "source": "/ve-digiwater", "destination": "/about.html" },
    { "source": "/dich-vu-xet-nghiem-nuoc-digiwater", "destination": "/services.html" },
    { "source": "/lien-he-digiwater", "destination": "/contact.html" }
  ]
}
